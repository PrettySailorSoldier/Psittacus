{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Psittacus",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:event:default",
    "core:event:allow-listen",
    "shell:allow-execute",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-read-dir",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "store:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ffmpeg",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/ffprobe",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
